generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
}

enum Role {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String               @id @default(uuid())
  email        String               @unique
  name         String
  password     String
  role         Role                 @default(USER)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  groupMembers         GroupMember[]
  expensesPaid         Expense[]            @relation("ExpensePaidBy")
  expenseParticipants  ExpenseParticipant[]
  debtsAsCreditor      Debt[]               @relation("DebtCreditor")
  debtsAsDebtor        Debt[]               @relation("DebtDebtor")
  settlementsAsPayer   Settlement[]         @relation("SettlementPayer")
  settlementsAsPayee   Settlement[]         @relation("SettlementPayee")

  @@map("users")
}

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  inviteToken String?       @unique @map("invite_token")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     GroupMember[]
  expenses    Expense[]
  debts       Debt[]
  settlements Settlement[]

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  userId    String?
  groupId   String
  alias     String
  createdAt DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([alias, groupId])
  @@map("group_members")
}

model Expense {
  id          String    @id @default(uuid())
  description String
  amount      Decimal   @db.Decimal(10, 2)
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  paidById String
  groupId  String

  paidBy       User                 @relation("ExpensePaidBy", fields: [paidById], references: [id], onDelete: Restrict)
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participants ExpenseParticipant[]
  debts        Debt[]

  @@map("expenses")
}

model ExpenseParticipant {
  id          String    @id @default(uuid())
  expenseId   String
  userId      String
  shareAmount Decimal   @db.Decimal(10, 2)
  splitType   SplitType @default(EQUAL)
  createdAt   DateTime  @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@map("expense_participants")
}

model Debt {
  id         String   @id @default(uuid())
  creditorId String
  debtorId   String
  amount     Decimal  @db.Decimal(10, 2)
  isSettled  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  groupId   String?
  expenseId String?

  creditor  User        @relation("DebtCreditor", fields: [creditorId], references: [id], onDelete: Restrict)
  debtor    User        @relation("DebtDebtor", fields: [debtorId], references: [id], onDelete: Restrict)
  group     Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  expense   Expense?    @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  settlements Settlement[]

  @@map("debts")
}

model Settlement {
  id        String   @id @default(uuid())
  payerId   String
  payeeId   String
  amount    Decimal  @db.Decimal(10, 2)
  notes     String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupId String?

  payer   User    @relation("SettlementPayer", fields: [payerId], references: [id], onDelete: Restrict)
  payee   User    @relation("SettlementPayee", fields: [payeeId], references: [id], onDelete: Restrict)
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  debts   Debt[]

  @@map("settlements")
}
